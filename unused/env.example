# Stripe
# Get from: dashboard.stripe.com → Developers → API keys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_key_here

# Google Analytics 4
# Property ID (numbers only, no "properties/" prefix)
GA4_PROPERTY_ID=123456789

# Google Service Account (for GA4 Data API)
# Option A: path to downloaded JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Option B: JSON contents directly (useful for serverless/env-var-only setups)
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
