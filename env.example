# Meta (Facebook) Ads
# Get this from developers.facebook.com → Your App → Marketing API
# Use a System User token for production (non-expiring)
META_ACCESS_TOKEN=your_long_lived_user_or_system_user_token
META_AD_ACCOUNT_ID=act_123456789

# SamCart
# Get this from SamCart → Settings → Integrations → API Keys
SAMCART_API_KEY=your_samcart_api_key
